# Copy this file to .env and fill in the key for whichever LLM provider
# you configured in registries/github_assistant.hocon / config/llm_config.hocon.

MISTRAL_API_KEY=your-mistral-api-key-here

# Or, if you switch model_name / class to another provider:
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Required so neuro-san finds this repo's registry and coded tools:
AGENT_MANIFEST_FILE=./registries/manifest.hocon
AGENT_TOOL_PATH=./coded_tools
